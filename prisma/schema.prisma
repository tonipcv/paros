generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  STARTER
  PRO
  MAX
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SettlementStatus {
  RESERVED
  SETTLED
  RELEASED
  RECONCILIATION_REQUIRED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace?
  sessions  Session[]
  passwordResets PasswordResetToken[]
  emailVerifications EmailVerificationToken[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("My Workspace")
  plan      Plan     @default(FREE)
  credits   Int      @default(10)
  onboardingCompleted Boolean @default(false)
  privacyMode Boolean @default(false)
  encEnabled  Boolean  @default(false)
  encSalt     String?
  encCheckIv  String?
  encCheckCt  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription       Subscription?
  conversations      Conversation[]
  images             GeneratedImage[]
  apiKeys            ApiKey[]
  usage              UsageEvent[]
  characters         Character[]
  dailySpends        WorkspaceDailySpend[]

  @@map("workspaces")
}

model Character {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  tagline      String   @default("")
  emoji        String   @default("🤖")
  systemPrompt String   @db.Text
  greeting     String   @default("") @db.Text
  model        String   @default("")
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]

  @@index([workspaceId])
  @@map("characters")
}

model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @unique
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("subscriptions")
}

model Conversation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  title       String    @default("New chat")
  model       String    @default("")
  ephemeral   Boolean   @default(false)
  temperature Float     @default(0.7)
  systemPrompt String?  @db.Text
  encrypted   Boolean   @default(false)
  titleIv     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages Message[]

  @@index([workspaceId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  attachments    Json         @default("[]")
  encrypted      Boolean      @default(false)
  iv             String?
  model          String?
  tokens         Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

model GeneratedImage {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prompt      String    @db.Text
  model       String
  style       String    @default("none")
  url         String    @db.Text
  width       Int       @default(1024)
  height      Int       @default(1024)
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@map("generated_images")
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@map("api_keys")
}

// ── Daily spend tracking ──

model WorkspaceDailySpend {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  spentMicros   BigInt   @default(0)
  reservedMicros BigInt   @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([workspaceId, date])
  @@index([workspaceId, date])
  @@map("workspace_daily_spends")
}

// ── Concurrency leases (distributed, TTL-based, survives connection drops) ──

model ConcurrencyLease {
  id          String   @id @default(cuid())
  workspaceId String
  slot        Int
  requestId   String
  expiresAt   DateTime

  @@unique([workspaceId, slot])
  @@index([workspaceId])
  @@index([expiresAt])
  @@map("concurrency_leases")
}

// ── Inference attempts (one per upstream call, created BEFORE fetch) ──

enum AttemptStatus {
  CREATED
  SENT
  STREAMING
  SETTLED
  RELEASED
  RECONCILIATION_REQUIRED
  FAILED
}

// ── Usage events (one per settled inference request) ──

model UsageEvent {
  id           String           @id @default(cuid())
  workspaceId  String
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  kind         String
  model        String           @default("")
  credits      Int              @default(0)
  tokens       Int              @default(0)
  costUsd      BigInt           @default(0)
  generationId String?
  settlement   SettlementStatus @default(RESERVED)
  createdAt    DateTime         @default(now())

  attempts     InferenceAttempt[]

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([generationId])
  @@map("usage_events")
}

model InferenceAttempt {
  id            String        @id @default(cuid())
  usageEventId  String
  usageEvent    UsageEvent    @relation(fields: [usageEventId], references: [id], onDelete: Cascade)
  attemptNumber Int           @default(1)
  generationId  String?
  provider      String        @default("")
  modelServed   String        @default("")
  costMicros    BigInt        @default(0)
  tokens        Int           @default(0)
  status        AttemptStatus @default(CREATED)
  errorMessage  String?
  createdAt     DateTime      @default(now())

  @@index([usageEventId])
  @@index([generationId])
  @@map("inference_attempts")
}

model StripeEvent {
  id          String    @id
  type        String
  status      String    @default("PROCESSING")
  error       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("stripe_events")
}

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart BigInt   @default(0)
  updatedAt   DateTime @updatedAt

  @@map("rate_limits")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("email_verification_tokens")
}

model HealthCheck {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("healthy")
  message   String?
  durationMs Int?
  alertSent  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@map("health_checks")
}

model AdminAction {
  id           String   @id @default(cuid())
  adminId      String
  adminEmail   String
  action       String
  targetUserId String?
  targetEmail  String?
  details      String?
  createdAt    DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetUserId])
  @@map("admin_actions")
}
