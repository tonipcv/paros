DATABASE_URL="postgres://user:pass:5432/db"

# OpenRouter (https://openrouter.ai/keys) — required for real inference
OPENROUTER_API_KEY="YOUR_KEY_HERE"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Default models
DEFAULT_CHAT_MODEL="meta-llama/llama-3.3-70b-instruct"
DEFAULT_IMAGE_MODEL="google/gemini-2.5-flash-image"

# OpenAI (voice: TTS + STT) — shared with gedi
OPENAI_API_KEY="YOUR_KEY_HERE"

NEXT_PUBLIC_APP_URL="http://localhost:3012"
NEXT_PUBLIC_APP_NAME="KRX"

# Stripe (live — shared with gedi)
STRIPE_SECRET_KEY=YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_KEY_HERE
STRIPE_PRICE_STARTER=YOUR_KEY_HERE
STRIPE_PRICE_PRO=YOUR_KEY_HERE
STRIPE_PRICE_MAX=YOUR_KEY_HERE
STRIPE_PRICE_STARTER_YEARLY=YOUR_KEY_HERE
STRIPE_PRICE_PRO_YEARLY=YOUR_KEY_HERE
STRIPE_PRICE_MAX_YEARLY=YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY=YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PRICE_MAX_YEARLY=YOUR_KEY_HERE

# Google OAuth (shared with gedi)
# Redirect URI registrado no Google Console (mesmo do gedi):
#   http://localhost:3012/api/google/callback
GOOGLE_CLIENT_ID=YOUR_KEY_HERE
GOOGLE_CLIENT_SECRET=YOUR_KEY_HERE

# Cloudflare R2 (object storage for images) — https://dash.cloudflare.com > R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Cloudflare Turnstile (anti-bot) — https://dash.cloudflare.com > Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Privacy: route only to non-retention providers (default true; set "false" to disable)
PRIVACY_NO_RETENTION="true"

# --- TEE / E2EE (Phala Confidential AI) ---
# https://docs.phala.network —
# PHALA_TEE_ENDPOINT="https://inference.phala.com/v1"
# PHALA_E2EE_ENDPOINT="https://inference.phala.com/v1"
# PHALA_TEE_API_KEY="ph-..."
# PHALA_E2EE_API_KEY="ph-..."
# TEE_ATTESTATION_URL=""   # override attestation report URL
# TEE_VERIFIER_URL=""      # override attestation verifier
# TEE_ATTESTATION_DISABLED="true"  # dev escape hatch — NOT for production

# Seed demo user
DEMO_USER_PASSWORD="ChangeMePlease123!"

# Cron secret — protects the /api/cron/* endpoints
CRON_SECRET=""

# Transactional email (outbound). Primary = Cloudflare Email Service (native):
# the domain heuv.dev is onboarded for sending and Cloudflare manages
# DKIM/SPF/DMARC in its own DNS. Create an API token with "Email Sending: Edit".
EMAIL_FROM="KRX <krx@heuv.dev>"
EMAIL_REPLY_TO="krx@heuv.dev"
EMAIL_PROVIDER="cloudflare"                # cloudflare | mailchannels | resend
CF_EMAIL_API_TOKEN=""                      # Cloudflare API token, "Email Sending: Edit"
CLOUDFLARE_ACCOUNT_ID=""                   # defaults to R2_ACCOUNT_ID if unset
# Alternative providers (optional):
# MAILCHANNELS_API_KEY=""
# MAILCHANNELS_DKIM_DOMAIN="heuv.dev"
# MAILCHANNELS_DKIM_SELECTOR="mailchannels"
# MAILCHANNELS_DKIM_PRIVATE_KEY=""
# RESEND_API_KEY=""
