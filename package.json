{
  "name": "venice-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3012",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start -p 3012",
    "test:pricing": "node --import tsx tests/pricing-model.test.ts",
    "test:e2e:pricing": "node --import tsx tests/e2e-pricing-http.test.ts",
    "test:stripe:sandbox": "node --import tsx tests/stripe-sandbox.test.ts",
    "test:stripe:webhook:local": "node --import tsx tests/stripe-webhook-local.test.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "stripe:webhook:create": "node scripts/create-stripe-webhook.mjs",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@prisma/client": "^6.7.0",
    "@stripe/stripe-js": "^9.8.0",
    "aws4fetch": "^1.0.20",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "next": "^15.1.0",
    "node-fetch-native": "^1.6.7",
    "prisma": "^6.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.0",
    "stripe": "^17.5.0",
    "unpdf": "^1.6.2",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
